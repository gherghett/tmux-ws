#!/usr/bin/env bash
# Desktop notification on Claude stop/attention events.
# Args: $1=event $2=pane_id $3=status_file
[ "$1" = "active" ] && exit 0

STATE=$(grep '^state=' "$3" 2>/dev/null | cut -d= -f2)
MSG=$(grep '^message=' "$3" 2>/dev/null | cut -d= -f2)
SESSION=$(tmux display-message -t "%$2" -p '#S' 2>/dev/null)

case "$STATE" in
  Attention) notify-send -u critical "Claude · $SESSION" "${MSG:-Needs input}" 2>/dev/null ;;
  Done)      notify-send "Claude · $SESSION" "${MSG:-Done}" 2>/dev/null ;;
esac

#!/usr/bin/env bash
# Launch or attach to the workspace manager

SESSION_NAME="${1:-main}"

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  tmux attach -t "$SESSION_NAME"
else
  # Create initial workspace
  tmux new-session -d -s "$SESSION_NAME"

  # Optionally create a few default workspaces
  if [ "$SESSION_NAME" = "main" ]; then
    tmux new-session -d -s "code" -c "$HOME/projects" 2>/dev/null || true
    tmux new-session -d -s "servers" 2>/dev/null || true
    tmux new-session -d -s "scratch" 2>/dev/null || true
  fi

  tmux attach -t "$SESSION_NAME"
fi
